# Local Development Database Configuration
# Copy this file to .env.local and update with your local MySQL credentials

# Local MySQL Database (Direct Connection)
DATABASE_URL="mysql://user:password@localhost:3306/localperks?sslaccept=strict"

# No Accelerate needed for local development
# PRISMA_ACCELERATE_ENDPOINT=

# Local Environment
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000

# Mailtrap Email Service (for development/testing)
# Get credentials from https://mailtrap.io
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=your_mailtrap_username
MAILTRAP_PASSWORD=your_mailtrap_password

# Copy other environment variables from .env as needed
# (API keys, secrets, etc. - but use local/test values)





