# Local Development Database Configuration
# Copy this file to .env.local and update with your local MySQL credentials

# Local MySQL Database (Direct Connection)
DATABASE_URL="mysql://user:password@localhost:3306/localperks?sslaccept=strict"

# No Accelerate needed for local development
# PRISMA_ACCELERATE_ENDPOINT=

# Local Environment
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000

# Mailtrap Email Service (for development/testing)
# Get credentials from https://mailtrap.io
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=your_mailtrap_username
MAILTRAP_PASSWORD=your_mailtrap_password

# Copy other environment variables from .env as needed
# (API keys, secrets, etc. - but use local/test values)


# Vonage (2FA - WhatsApp first, SMS fallback)
VONAGE_API_KEY=your_api_key
VONAGE_API_SECRET=your_api_secret
# For WhatsApp - create app at dashboard.nexmo.com, link WhatsApp number
VONAGE_APPLICATION_ID=your_application_id
VONAGE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# WhatsApp number - try WhatsApp first (14157386102 = sandbox)
VONAGE_WHATSAPP_NUMBER=14157386102
# SMS number; omit to use Vonage Verify for SMS fallback
VONAGE_SMS_NUMBER=447700900000
# true = WhatsApp sandbox (users must join sandbox first)
VONAGE_MESSAGES_SANDBOX=true




