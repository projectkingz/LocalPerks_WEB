# Production Database Configuration (PlanetScale via Prisma Accelerate)
# Copy this file to .env.production or set in Vercel environment variables

# PlanetScale via Prisma Accelerate
DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=YOUR_API_KEY"
PRISMA_ACCELERATE_ENDPOINT="prisma+mysql://accelerate.prisma-data.net/?api_key=YOUR_API_KEY"

# Production Environment
NODE_ENV=production
NEXTAUTH_URL=https://your-domain.vercel.app

# Mailtrap Email Service (for production)
# For production, you can use Mailtrap's production SMTP or switch to another service
# Get credentials from https://mailtrap.io
MAILTRAP_HOST=smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=your_mailtrap_username
MAILTRAP_PASSWORD=your_mailtrap_password

# Copy other production environment variables here
# (API keys, secrets, etc.)

# Vonage (2FA - WhatsApp first, SMS fallback)
VONAGE_API_KEY=c2eb2284
VONAGE_API_SECRET= ^x0g7yhRsRC3p    
