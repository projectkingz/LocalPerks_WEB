{
  "name": "my-rewards",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "echo 'Build script: Running prisma generate...' && prisma generate --schema=./prisma/schema.prisma --accelerate && echo 'Build script: Prisma generate completed, starting Next.js build...' && next build",
    "build:vercel": "prisma generate --schema=./prisma/schema.prisma --accelerate && next build",
    "build:analyze": "ANALYZE=true next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "postinstall": "echo 'Running postinstall: prisma generate (direct connection for local dev)' && prisma generate --schema=./prisma/schema.prisma && echo 'Prisma generate completed'",
    "seed": "ts-node -P prisma/tsconfig.json prisma/seed.ts",
    "prisma:seed": "ts-node prisma/seed.ts",
    "seed:comprehensive": "ts-node prisma/seed-comprehensive.ts",
    "add:recent-data": "ts-node prisma/add-recent-data.ts",
    "test:recent-data": "ts-node prisma/test-recent-data.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:api": "jest __tests__/api",
    "db:local": "prisma --schema=./prisma/schema.prisma",
    "db:prod": "prisma --schema=./prisma/schema.prisma",
    "db:generate:local": "prisma generate --schema=./prisma/schema.prisma",
    "db:generate:prod": "prisma generate --schema=./prisma/schema.prisma --accelerate",
    "db:push:local": "prisma db push --schema=./prisma/schema.prisma",
    "db:push:prod": "prisma db push --schema=./prisma/schema.prisma",
    "db:migrate:local": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:studio:local": "prisma studio --schema=./prisma/schema.prisma",
    "db:studio:prod": "prisma studio --schema=./prisma/schema.prisma",
    "db:switch:local": "powershell -ExecutionPolicy Bypass -File ./scripts/switch-database.ps1 local",
    "db:switch:prod": "powershell -ExecutionPolicy Bypass -File ./scripts/switch-database.ps1 production",
    "db:setup:local": "npx tsx scripts/setup-local-db.ts",
    "mobile:update:all": "npx tsx scripts/batch-update-mobile.ts --all",
    "mobile:update:interactive": "npx tsx scripts/batch-update-mobile.ts",
    "mobile:update:csv": "npx tsx scripts/batch-update-mobile.ts --csv"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.9.1",
    "@expo/webpack-config": "^19.0.1",
    "@heroicons/react": "^2.1.1",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.19.0",
    "@prisma/extension-accelerate": "^2.0.2",
    "@types/bcryptjs": "2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.5",
    "@types/react-dom": "^18.3.7",
    "@upstash/redis": "^1.35.0",
    "@vonage/jwt": "^1.13.3",
    "autoprefixer": "^10.4.0",
    "bcryptjs": "^2.4.3",
    "browser-image-compression": "^2.0.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.3.4",
    "framer-motion": "^12.16.0",
    "html5-qrcode": "^2.3.8",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.513.0",
    "next": "^14.2.29",
    "next-auth": "^4.24.11",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.17.1",
    "postcss": "^8.4.0",
    "prisma": "^6.19.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.5.2",
    "react-icons": "^5.5.0",
    "react-native-web": "^0.21.1",
    "resend": "^4.5.2",
    "stripe": "^19.1.0",
    "tailwindcss": "^3.3.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.3.4",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/next": "^8.0.7",
    "@types/node": "^22.15.32",
    "@types/qrcode.react": "^1.0.5",
    "@types/react": "^18.3.23",
    "@types/uuid": "^10.0.0",
    "baseline-browser-mapping": "^2.8.31",
    "ignore-loader": "^0.1.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "description": "A modern rewards program that helps local businesses build customer loyalty and community engagement. Customers earn points for their purchases and can redeem them for rewards at their favorite local spots.",
  "main": "next.config.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/projectkingz/my-rewards-new.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/projectkingz/my-rewards-new/issues"
  },
  "homepage": "https://github.com/projectkingz/my-rewards-new#readme"
}
